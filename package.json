{
  "name": "blossum",
  "private": true,
  "description": "MoneyBlosSum — Vue 앱은 bank/sakura_bank_ver_vue 에 있습니다.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix bank/sakura_bank_ver_vue",
    "dev:api": "npm run dev --prefix backend/json-server",
    "build": "npm run build --prefix bank/sakura_bank_ver_vue",
    "install:web": "npm install --prefix bank/sakura_bank_ver_vue",
    "install:api": "npm install --prefix backend/json-server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue-chartjs": "^5.3.3"
  }
}
